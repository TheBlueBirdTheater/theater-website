---
import BaseLayout from './BaseLayout.astro';
import NavBar from '@components/NavBar.astro';
import Footer from '@components/Footer.astro';
import TocSidebar from '@components/TocSidebar.astro';
import BackToTop from '@components/BackToTop.astro';
import { resolveFrontmatter, type LayoutProps } from '@utils/frontmatter';

const props = Astro.props as LayoutProps;
const page = resolveFrontmatter(props);
const headings = (props.headings ?? []).filter((h) => h.depth === 2);
---

<BaseLayout frontmatter={page}>
  <NavBar />
  <div class="mx-auto grid max-w-5xl gap-8 px-4 py-10 md:grid-cols-[1fr_240px]">
    <main class="prose max-w-none">
      <h1>{page.title}</h1>
      <slot />
    </main>
    <TocSidebar headings={headings} />
  </div>
  <BackToTop />
  <Footer />
</BaseLayout>
