---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props as Props;
---

{headings.length > 0 && (
  <aside class="hidden md:block">
    <div class="sticky top-8">
      <p class="font-heading mb-2 text-sm font-semibold uppercase tracking-wide">On this page</p>
      <ul class="menu menu-sm gap-1">
        {headings.map((heading) => (
          <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
        ))}
      </ul>
    </div>
  </aside>
)}
