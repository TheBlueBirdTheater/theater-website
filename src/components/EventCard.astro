---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { formatEventDates } from '@utils/dates';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props as Props;
const { data } = event;

const singleDateTimes = data.showDates.length === 1 ? data.showDates[0].times : undefined;
---

<a
  href={`/events/${event.id}`}
  class="border-line bg-base-100 hover:shadow-raised flex flex-col overflow-hidden rounded-lg border no-underline shadow-card transition-all duration-200 hover:-translate-y-1"
>
  <div class="relative aspect-4/3 overflow-hidden">
    {data.image ? (
      <Image
        src={data.image}
        alt={data.imageAlt ?? data.title}
        format="webp"
        class="h-full w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="bg-base-200 text-base-content/60 font-body flex h-full w-full items-center justify-center text-sm">
        {formatEventDates(data.showDates)}
      </div>
    )}
  </div>
  <div class="flex flex-col gap-2 px-5.5 pt-5.5 pb-6">
    <h3 class="font-heading text-base-content text-[1.4rem] font-semibold tracking-[-0.01em]">{data.title}</h3>
    {data.host && <p class="font-body text-base-content/60 text-sm italic">Presented by {data.host}</p>}
    <p class="font-body text-base-content mt-1 text-sm font-medium">
      {formatEventDates(data.showDates)}
      {singleDateTimes && singleDateTimes.length > 0 && ` · ${singleDateTimes.map((t) => t.time).join(' & ')}`}
    </p>
  </div>
</a>
