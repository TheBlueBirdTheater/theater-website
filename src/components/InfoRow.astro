---
import type { IconDefinition } from '@fortawesome/fontawesome-svg-core';
import Icon from '@components/Icon.astro';

interface Props {
  icon?: string;
  iconDef?: IconDefinition;
  label: string;
  value: string;
  href?: string;
}

const { icon = '◆', iconDef, label, value, href } = Astro.props as Props;
---

<div class="font-body flex items-start gap-3">
  {iconDef ? (
    <Icon icon={iconDef} class="text-primary mt-0.5 h-4.5 w-4.5 shrink-0" />
  ) : (
    <span class="text-primary w-[22px] shrink-0 text-center text-callout leading-[1.4]">{icon}</span>
  )}
  <div>
    <div class="text-base-content/70 mb-0.5 text-eyebrow tracking-[0.09em] uppercase">{label}</div>
    {href ? (
      <a href={href} class="link link-primary text-base font-medium">{value}</a>
    ) : (
      <div class="text-base-content text-base font-medium">{value}</div>
    )}
  </div>
</div>
