---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Badge from '@components/Badge.astro';
import { formatDateRange } from '@utils/dates';
import { getShowStatus } from '@utils/shows';

interface Props {
  show: CollectionEntry<'shows'>;
}

const { show } = Astro.props as Props;
const { data } = show;
---

<a
  href={`/shows/${show.id}`}
  class="border-line bg-base-100 flex flex-col overflow-hidden rounded-lg border no-underline shadow-card"
>
  <div class="relative aspect-4/3 overflow-hidden">
    {data.posterImage ? (
      <Image
        src={data.posterImage}
        alt={data.posterAlt}
        format="webp"
        class="h-full w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="bg-base-200 text-base-content/60 font-body flex h-full w-full items-center justify-center text-sm">
        Poster coming soon
      </div>
    )}
    <div class="absolute top-3.5 left-3.5">
      <Badge status={getShowStatus(show)} />
    </div>
  </div>
  <div class="flex flex-col gap-2 px-5.5 pt-5.5 pb-6">
    <h3 class="font-heading text-base-content text-[1.4rem] font-semibold tracking-[-0.01em]">{data.title}</h3>
    {data.subtitle && <p class="font-body text-base-content/60 text-sm italic">{data.subtitle}</p>}
    <p class="font-body text-base-content mt-1 text-sm font-medium">
      {formatDateRange(data.runDates)}
      {' · '}{data.venue}
    </p>
  </div>
</a>
