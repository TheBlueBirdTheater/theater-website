---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Badge from '@components/Badge.astro';
import { formatDateRange } from '@utils/dates';
import { getShowStatus } from '@utils/shows';

interface Props {
  show: CollectionEntry<'shows'> | CollectionEntry<'archivedShows'>;
  /** Renders as a plain, non-linking card — used on the season archive page where no detail page exists. */
  archived?: boolean;
}

const { show, archived = false } = Astro.props as Props;
const { data } = show;
const Tag = archived ? 'div' : 'a';
---

<Tag
  href={archived ? undefined : `/shows/${show.id}`}
  class="border-line bg-base-100 flex flex-col overflow-hidden rounded-lg border no-underline shadow-card"
  class:list={[!archived && 'hover:shadow-raised transition-all duration-200 hover:-translate-y-1']}
>
  <div class="border-line relative aspect-4/3 overflow-hidden border-b">
    {data.posterImage ? (
      <Image
        src={data.posterImage}
        alt={data.posterAlt}
        format="webp"
        class="h-full w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="bg-base-200 text-base-content/70 font-body flex h-full w-full items-center justify-center text-sm">
        Poster coming soon
      </div>
    )}
    {!archived && (
      <div class="absolute top-3.5 left-3.5">
        <Badge status={getShowStatus(show as CollectionEntry<'shows'>)} />
      </div>
    )}
  </div>
  <div class="flex flex-col gap-2 px-5.5 pt-5.5 pb-6">
    <h3 class="font-heading text-base-content text-card-title font-semibold tracking-[-0.01em]">{data.title}</h3>
    {data.subtitle && <p class="font-body text-base-content/70 text-sm italic">{data.subtitle}</p>}
    <p class="font-body text-base-content mt-1 text-sm font-medium">
      {formatDateRange(data.runDates)}
      {' · '}{data.venue}
    </p>
  </div>
</Tag>
