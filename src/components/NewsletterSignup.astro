---
import Button from '@components/Button.astro';
---

<section class="mx-auto my-16 max-w-(--container-narrow) px-6 text-center">
  <p class="font-body text-primary mb-2.5 text-[0.8125rem] font-semibold tracking-[0.09em] uppercase">
    Stay In The Loop
  </p>
  <h2 class="font-heading text-base-content text-[2rem] leading-[1.2] font-semibold tracking-[-0.01em]">
    Get show announcements in your inbox
  </h2>
  <!-- TODO: wire up to a real newsletter provider (e.g. Mailchimp) once one is chosen -->
  <form class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row sm:items-end" action="#" method="post">
    <input
      type="email"
      name="email"
      required
      placeholder="Your email address"
      class="input input-bordered border-line text-base-content flex-1 rounded-md"
    />
    <Button type="submit" variant="primary">Join the List</Button>
  </form>
</section>
