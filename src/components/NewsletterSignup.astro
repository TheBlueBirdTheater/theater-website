<section class="bg-primary text-primary-content rounded-box mx-auto my-12 max-w-3xl px-6 py-10 text-center">
  <h2 class="font-heading text-2xl font-bold">Stay in the loop</h2>
  <p class="mt-2">Get show announcements, audition notices, and ticket alerts in your inbox.</p>
  <!-- TODO: wire up to a real newsletter provider (e.g. Mailchimp) once one is chosen -->
  <form class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-center" action="#" method="post">
    <input
      type="email"
      name="email"
      required
      placeholder="you@example.com"
      class="input input-bordered text-base-content w-full sm:w-72"
    />
    <button type="submit" class="btn btn-secondary">Sign Up</button>
  </form>
</section>
