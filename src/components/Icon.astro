---
import type { IconDefinition } from '@fortawesome/fontawesome-svg-core';
import { iconToSvg } from '@utils/icon';

interface Props {
  icon: IconDefinition;
  class?: string;
}

const { icon, class: className = 'h-5 w-5' } = Astro.props as Props;
const svg = iconToSvg(icon, className);
---

<Fragment set:html={svg} />
