---
interface Props {
  status: 'current' | 'upcoming' | 'past';
}

const { status } = Astro.props as Props;

const labels = {
  current: 'Now Playing',
  upcoming: 'Upcoming',
  past: 'Past',
};

const classes = {
  current: 'bg-primary text-primary-content',
  upcoming: 'bg-light-blue-tint text-accent',
  past: 'bg-base-300 text-base-content/70',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full px-3 py-1.25 font-body text-eyebrow font-semibold tracking-[0.09em] uppercase',
    classes[status],
  ]}
>
  <slot>{labels[status]}</slot>
</span>
