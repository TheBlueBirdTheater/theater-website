---
import { Image } from "astro:assets";
import { faBars, faXmark } from "@fortawesome/free-solid-svg-icons";
import Icon from "@components/Icon.astro";
import Button from "@components/Button.astro";
import logoMark from "@assets/logo-mark.svg";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/shows", label: "Shows" },
  { href: "/auditions", label: "Auditions" },
  { href: "/about", label: "About" },
  { href: "/volunteer", label: "Volunteer" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="bg-base-100 border-base-300 sticky top-0 z-20 border-b">
  <div class="navbar mx-auto max-w-(--container-max) px-4">
    <div class="navbar-start">
      <a
        href="/"
        class="flex items-center gap-2"
        aria-label="Blue Bird Theatre home"
      >
        <Image src={logoMark} alt="Blue Bird Theatre logo" width={40} height={40} />
        <span
          class="font-heading text-base-content text-xl font-bold tracking-[-0.01em]"
        >
          Blue Bird Theatre
        </span>
      </a>
    </div>
    <nav
      class="navbar-end hidden items-center gap-7 lg:flex"
      aria-label="Primary"
    >
      <ul class="flex items-center gap-7">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
                class:list={[
                  "font-body border-b-2 pb-1 text-sm font-medium",
                  isActive(link.href)
                    ? "border-primary text-primary"
                    : "border-transparent text-base-content",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <Button href="/donate" variant="secondary" size="sm">Donate</Button>
      <Button href="/tickets" variant="primary" size="sm">Get Tickets</Button>
    </nav>
    <div class="navbar-end gap-2 lg:hidden">
      <Button href="/tickets" variant="primary" size="sm">Tickets</Button>
      <details class="dropdown dropdown-end group">
        <summary
          class="btn btn-ghost btn-square list-none [&::-webkit-details-marker]:hidden"
          aria-label="Toggle menu"
        >
          <Icon icon={faBars} class="h-5 w-5 group-open:hidden" />
          <Icon icon={faXmark} class="hidden h-5 w-5 group-open:block" />
        </summary>
        <ul
          class="menu dropdown-content bg-base-100 rounded-box z-10 mt-2 w-56 p-2 shadow"
          aria-label="Primary"
        >
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                  class:list={[
                    "font-body text-sm font-medium",
                    isActive(link.href) && "text-primary",
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="border-line mt-1 border-t pt-1">
            <a href="/donate" class="font-body text-sm font-medium">Donate</a>
          </li>
        </ul>
      </details>
    </div>
  </div>
</header>
