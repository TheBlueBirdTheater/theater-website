---
import Button from '@components/Button.astro';

const navLinks = [
  { href: '/shows', label: 'Shows' },
  { href: '/auditions', label: 'Auditions' },
  { href: '/volunteer', label: 'Get Involved' },
  { href: '/donate', label: 'Support Us' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="bg-base-100 border-base-300 sticky top-0 z-20 border-b">
  <div class="navbar mx-auto max-w-(--container-max) px-4">
    <div class="navbar-start">
      <a href="/" class="font-heading text-base-content text-xl font-bold tracking-[-0.01em]">
        Orangeburg Part-Time Players
      </a>
    </div>
    <nav class="navbar-end hidden items-center gap-7 lg:flex">
      <ul class="flex items-center gap-7">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'font-body border-b-2 pb-1 text-sm font-medium',
                isActive(link.href) ? 'border-primary text-primary' : 'border-transparent text-base-content',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <Button href="/tickets" variant="primary" size="sm">Get Tickets</Button>
    </nav>
    <div class="navbar-end gap-2 lg:hidden">
      <Button href="/tickets" variant="primary" size="sm">Tickets</Button>
      <details class="dropdown dropdown-end">
        <summary class="btn btn-ghost">Menu</summary>
        <ul class="menu dropdown-content bg-base-100 rounded-box z-10 mt-2 w-52 p-2 shadow">
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </details>
    </div>
  </div>
</header>
