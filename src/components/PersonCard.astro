---
import type { CollectionEntry } from 'astro:content';

interface Props {
  person: CollectionEntry<'team'>;
}

const { person } = Astro.props as Props;
const { name, role, bio, photoUrl } = person.data;
---

<div class="flex items-center gap-4">
  {photoUrl ? (
    <img src={photoUrl} alt={name} class="h-16 w-16 shrink-0 rounded-full object-cover" loading="lazy" />
  ) : (
    <div class="bg-base-300 text-base-content/60 font-body flex h-16 w-16 shrink-0 items-center justify-center rounded-full text-[10px]">
      Photo
    </div>
  )}
  <div>
    <div class="font-body text-base-content font-semibold">{name}</div>
    <div class="font-body text-primary text-sm">{role}</div>
    {bio && <div class="font-body text-base-content/60 mt-1">{bio}</div>}
  </div>
</div>
