---
import type { PageFrontmatter } from '@utils/types';
export type { PageFrontmatter };

interface Props extends PageFrontmatter {}

const {
  title,
  description,
  image = '/images/og-default.jpg', // default 1200x630 OG/social share image — see public/images/og-default.README.md
  imageAlt,
  type = 'website',
  noindex = false,
  canonical,
} = Astro.props as Props;

const siteName = 'Blue Bird Theatre';
const pageTitle = `${title} | ${siteName}`;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const resolvedImageAlt =
  imageAlt ??
  (image === '/images/og-default.jpg'
    ? 'Stylized illustration of the Blue Bird Theatre marquee and facade in downtown Orangeburg, SC'
    : '');
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
{resolvedImageAlt && <meta property="og:image:alt" content={resolvedImageAlt} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
