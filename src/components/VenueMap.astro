---
import { faLocationDot } from '@fortawesome/free-solid-svg-icons';
import Icon from '@components/Icon.astro';

interface Props {
  address: string;
  lat?: number;
  lng?: number;
  height?: number;
}

const { address, lat, lng, height = 320 } = Astro.props as Props;

// Presence must be a type check, not a truthy check — 0 is a valid (if placeholder) coordinate.
const hasCoords = typeof lat === 'number' && typeof lng === 'number';

const BBOX_DELTA = 0.006;
const embedUrl = hasCoords
  ? `https://www.openstreetmap.org/export/embed.html?bbox=${lng! - BBOX_DELTA}%2C${lat! - BBOX_DELTA}%2C${lng! + BBOX_DELTA}%2C${lat! + BBOX_DELTA}&layer=mapnik&marker=${lat}%2C${lng}`
  : undefined;

const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`;
---

<div>
  {hasCoords ? (
    <iframe
      src={embedUrl}
      loading="lazy"
      title={`Map showing ${address}`}
      class="border-line w-full rounded-lg border"
      style={`height: ${height}px`}
    />
  ) : (
    <div
      class="border-line bg-base-200 text-base-content/60 font-body flex w-full items-center justify-center rounded-lg border text-sm"
      style={`height: ${height}px`}
    >
      Map coming soon
    </div>
  )}
  <div class="mt-3">
    <a href={directionsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-primary gap-2">
      <Icon icon={faLocationDot} class="h-4 w-4" />
      Get Directions
    </a>
  </div>
</div>
