---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import { faqs } from '@data/faqs';
---

<DefaultLayout title="FAQ" description="Frequently asked questions about OPTP and the Blue Bird Theatre.">
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="font-heading text-3xl font-bold">Frequently Asked Questions</h1>
    <div class="mt-8 space-y-2">
      {faqs.map((faq) => (
        <div class="collapse-arrow bg-base-200 collapse">
          <input type="checkbox" />
          <div class="collapse-title font-semibold">{faq.question}</div>
          <div class="collapse-content"><p>{faq.answer}</p></div>
        </div>
      ))}
    </div>
  </div>
</DefaultLayout>
