---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Button from '@components/Button.astro';
---

<DefaultLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex>
  <div class="mx-auto max-w-xl px-4 py-24 text-center">
    <h1 class="font-heading text-base-content text-4xl font-bold">404</h1>
    <p class="font-body text-base-content mt-4">Sorry, we couldn't find that page.</p>
    <Button href="/" variant="primary" class="mt-6">Back to Home</Button>
  </div>
</DefaultLayout>
