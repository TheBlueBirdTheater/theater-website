---
import DefaultLayout from '@layouts/DefaultLayout.astro';
---

<DefaultLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex>
  <div class="mx-auto max-w-xl px-4 py-24 text-center">
    <h1 class="font-heading text-4xl font-bold">404</h1>
    <p class="mt-4">Sorry, we couldn't find that page.</p>
    <a href="/" class="btn btn-primary mt-6">Back to Home</a>
  </div>
</DefaultLayout>
