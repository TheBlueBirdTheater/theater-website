---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Button from '@components/Button.astro';
import { buildEventSchema, buildBreadcrumbSchema, OPTP_NAME } from '@utils/schema';
import { getCurrentShow } from '@utils/shows';
import { getEntry } from 'astro:content';

const currentShow = await getCurrentShow();
const firstRunDate = currentShow?.data.runDates[0];
const { data: contact } = (await getEntry('contact', 'contact'))!;

const eventSchema = currentShow && firstRunDate
  ? buildEventSchema({
      name: currentShow.data.title,
      startDate: `${firstRunDate.date}T${firstRunDate.time}:00`,
      url: `/shows/${currentShow.id}`,
      venueName: currentShow.data.venue,
      venueAddress: {
        streetAddress: contact.address.line1,
        addressLocality: contact.address.city,
        addressRegion: contact.address.state,
        postalCode: contact.address.zip,
      },
      performerName: currentShow.data.performingGroup ?? OPTP_NAME,
      offerUrl: currentShow.data.ticketUrl,
      offerPrice: currentShow.data.ticketPrice,
      description: currentShow.data.synopsis,
    })
  : null;

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Tickets', url: '/tickets' },
]);
---

<DefaultLayout title="Tickets" description="Buy tickets to OPTP's current production at the Blue Bird Theatre.">
  {eventSchema && <Schema schema={eventSchema} />}
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto max-w-(--container-narrow) px-4 py-16">
    <SectionHeading title="Tickets & Box Office" />

    {currentShow && (
      <div class="mt-8">
        <h2 class="font-heading text-base-content text-xl font-semibold">{currentShow.data.title}</h2>
        <p class="font-body text-base-content mt-2">{currentShow.data.synopsis}</p>
        <Button href={currentShow.data.ticketUrl} variant="primary" size="lg" class="mt-6">Buy Tickets</Button>
      </div>
    )}

    <!-- TODO: embed a real third-party ticketing widget here once a platform is chosen
         (e.g. Eventbrite, Ticketleap, Showpass). Currently linking out via ticketUrl only. -->
    <p class="font-body text-base-content/60 mt-8 text-sm">[TODO: ticketing platform integration pending]</p>
  </div>
</DefaultLayout>
