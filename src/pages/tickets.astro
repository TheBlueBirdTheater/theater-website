---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import { buildEventSchema } from '@utils/schema';
import { getCurrentShow } from '@data/season';

const currentShow = getCurrentShow();
const firstRunDate = currentShow?.runDates[0];

const eventSchema = currentShow && firstRunDate
  ? buildEventSchema({
      name: currentShow.title,
      startDate: `${firstRunDate.date}T${firstRunDate.time}:00`,
      url: `/shows/${currentShow.slug}`,
      venueName: currentShow.venue,
      offerUrl: currentShow.ticketUrl,
      description: currentShow.synopsis,
    })
  : null;
---

<DefaultLayout title="Tickets" description="Buy tickets to OPTP's current production at the Blue Bird Theatre.">
  {eventSchema && <Schema schema={eventSchema} />}

  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="font-heading text-3xl font-bold">Tickets &amp; Box Office</h1>

    {currentShow && (
      <div class="mt-8">
        <h2 class="font-heading text-xl font-semibold">{currentShow.title}</h2>
        <p class="mt-2">{currentShow.synopsis}</p>
        <a href={currentShow.ticketUrl} class="btn btn-primary mt-6">Buy Tickets</a>
      </div>
    )}

    <!-- TODO: embed a real third-party ticketing widget here once a platform is chosen
         (e.g. Eventbrite, Ticketleap, Showpass). Currently linking out via ticketUrl only. -->
    <p class="mt-8 text-sm opacity-70">[TODO: ticketing platform integration pending]</p>
  </div>
</DefaultLayout>
