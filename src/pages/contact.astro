---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import SectionHeading from '@components/SectionHeading.astro';
import InfoRow from '@components/InfoRow.astro';
import { buildBreadcrumbSchema } from '@utils/schema';
import { getEntry } from 'astro:content';

const { data: contact } = (await getEntry('contact', 'contact'))!;

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
]);
---

<DefaultLayout title="Contact" description="Get in touch with the Blue Bird Theatre.">
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto max-w-(--container-narrow) px-4 py-16">
    <SectionHeading title="Contact Us" />

    <div class="mt-8 flex flex-col gap-5">
      <InfoRow label="Phone" value={contact.phone} href={`tel:${contact.phone}`} />
      <InfoRow label="Email" value={contact.email} href={`mailto:${contact.email}`} />
      <InfoRow
        label="Address"
        value={`Blue Bird Theatre, ${contact.address.line1}, ${contact.address.city}, ${contact.address.state} ${contact.address.zip}`}
      />
    </div>

    <div class="mt-6 flex gap-4">
      {contact.socials.map((social) => (
        <a href={social.url} class="link link-primary">{social.platform}</a>
      ))}
    </div>
  </div>
</DefaultLayout>
