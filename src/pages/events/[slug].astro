---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import { Image } from 'astro:assets';
import Button from '@components/Button.astro';
import ShareButton from '@components/ShareButton.astro';
import InfoRow from '@components/InfoRow.astro';
import VenueMap from '@components/VenueMap.astro';
import AddToCalendar from '@components/AddToCalendar.astro';
import KnowBeforeYouGo from '@components/KnowBeforeYouGo.astro';
import CountdownBanner from '@components/CountdownBanner.astro';
import AuditionNotice from '@components/AuditionNotice.astro';
import Divider from '@components/Divider.astro';
import { isAuditionActive } from '@utils/auditions';
import { faShirt } from '@fortawesome/free-solid-svg-icons';
import { buildEventSchema, buildBreadcrumbSchema } from '@utils/schema';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import { getVenueContact, THEATRE_NAME } from '@data/venue';
import { formatDate, formatEventDates, formatTime } from '@utils/dates';
import { getNextShowing, toVenueIsoString, type Showing } from '@utils/showings';
import { formatAccessibilitySummary } from '@utils/accessibility';
import { isBuildableSeason } from '@utils/seasons';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events
    .filter((event) => isBuildableSeason(event.data.season))
    .map((event) => ({
      params: { slug: event.id },
      props: { event },
    }));
}

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props as Props;
const { data } = event;

const contact = await getVenueContact();

const venueAddress = `${THEATRE_NAME}, ${contact.address.streetAddress}, ${contact.address.addressLocality}, ${contact.address.addressRegion} ${contact.address.postalCode}`;

const showings: Showing[] = data.showDates.flatMap((sd) =>
  sd.times && sd.times.length > 0
    ? sd.times.map((t) => ({ date: sd.date, time: t.time, label: t.label, accessibilityTag: t.accessibilityTag }))
    : [{ date: sd.date }]
);
const { next: nextShowing, isPast: allShowingsPast } = getNextShowing(showings);

const parkingFaq = await getEntry('faqs', 'venue-parking');
const locationFaq = await getEntry('faqs', 'venue-location');

const eventSchemas = data.showDates.flatMap((sd) =>
  (sd.times && sd.times.length > 0 ? sd.times : [undefined]).map((t) =>
    buildEventSchema({
      name: data.title,
      startDate: (t ? toVenueIsoString({ date: sd.date, time: t.time }) : null) ?? sd.date,
      url: `/events/${event.id}`,
      venueName: THEATRE_NAME,
      venueAddress: contact.address,
      performerName: data.host,
      offerUrl: data.ticketUrl,
      offerPrice: data.ticketPrice,
      description: data.description,
      imageUrl: data.image?.src,
    })
  )
);

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Shows', url: '/shows' },
  { name: data.title, url: `/events/${event.id}` },
]);
---

<DefaultLayout
  title={data.title}
  description={data.description}
  image={data.image?.src}
  imageAlt={data.imageAlt}
>
  <Schema schema={eventSchemas} />
  <Schema schema={breadcrumbSchema} />

  <CountdownBanner next={nextShowing} isPast={allShowingsPast} />

  <div class="mx-auto grid max-w-(--container-max) gap-14 px-4 py-14 md:grid-cols-[0.85fr_1.15fr]">
    {data.image ? (
      <Image
        src={data.image}
        alt={data.imageAlt ?? data.title}
        format="webp"
        class="border-line w-full min-w-0 self-start rounded-lg border shadow-card"
      />
    ) : (
      <div class="border-line rounded-lg bg-base-200 text-base-content/70 font-body flex aspect-video w-full min-w-0 items-center justify-center border text-sm">
        {formatEventDates(data.showDates)}
      </div>
    )}
    <div>
      <h1 class="font-heading text-base-content text-display leading-[1.08] font-semibold tracking-[-0.01em]">
        {data.title}
      </h1>
      {data.host && <p class="font-body text-base-content/70 mt-2 text-lead italic">Presented by {data.host}</p>}
      <p class="font-body text-base-content mt-4">{data.description}</p>

      <div class="mt-7 grid gap-4.5 sm:grid-cols-2">
        <InfoRow label="Venue" value={THEATRE_NAME} />
        {data.dressCode && <InfoRow label="Dress Code" value={data.dressCode} iconDef={faShirt} />}
      </div>

      <div class="mt-4.5">
        <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">Showtimes</p>
        {data.showDates.length === 0 ? (
          <p class="font-body text-base-content mt-2">TBA</p>
        ) : (
          <ul class="font-body text-base-content mt-2 space-y-1">
            {data.showDates.map((sd) => (
              <li>
                {formatDate(sd.date)}
                {' — '}
                {sd.times && sd.times.length > 0 ? (
                  sd.times.map((t, i) => (
                    <>
                      {t.label ? `${t.label}: ${formatTime(t.time)}` : formatTime(t.time)}
                      {t.accessibilityTag && ` (${t.accessibilityTag})`}
                      {i < sd.times!.length - 1 && ' & '}
                    </>
                  ))
                ) : (
                  'Time TBA'
                )}
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="mt-7">
        <VenueMap address={venueAddress} lat={contact.mapLat} lng={contact.mapLng} />
      </div>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        {data.ticketUrl && (
          <Button href={data.ticketUrl} variant="primary" size="lg">
            {data.ticketPrice ? `Get Tickets · ${data.ticketPrice}` : 'Get Tickets'}
          </Button>
        )}
        <AddToCalendar
          title={data.title}
          address={venueAddress}
          showings={showings}
          ticketUrl={data.ticketUrl}
          description={data.description}
        />
        <ShareButton title={data.title} size="lg" />
      </div>

      <div class="mt-7">
        <KnowBeforeYouGo
          doorsOpenMinutesBefore={data.doorsOpenMinutesBefore}
          runTime={data.runTime}
          parkingAnswer={parkingFaq?.data.answer}
          locationAnswer={locationFaq?.data.answer}
          accessibilityNote={formatAccessibilitySummary(data.accessibility)}
          concessionsNote={data.concessionsNote}
          dressCode={data.dressCode}
        />
      </div>

      {data.performers && data.performers.length > 0 && (
        <div class="mt-10">
          <Divider />
          <div class="mt-8">
            <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">
              Performances By
            </p>
            <p class="font-body text-base-content mt-2 leading-[1.9]">
              {data.performers.map((performer, i) => (
                <>
                  {performer}
                  {i < data.performers!.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        </div>
      )}

      {data.auditions && isAuditionActive(data.auditions) && (
        <div class="mt-10">
          <Divider />
          <div class="mt-8">
            <AuditionNotice
              title={`Auditions for ${data.title}`}
              readMoreHref={`/auditions/${event.id}`}
              auditions={data.auditions}
              fallbackContactEmail={contact.email}
            />
          </div>
        </div>
      )}
    </div>
  </div>
</DefaultLayout>
