---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import SectionHeading from '@components/SectionHeading.astro';
import DivisionAuditionPanel from '@components/DivisionAuditionPanel.astro';
import AuditionNotice from '@components/AuditionNotice.astro';
import { buildBreadcrumbSchema } from '@utils/schema';
import { getAuditioningNow } from '@utils/auditions';
import { getVenueContact } from '@data/venue';
import { getEntry } from 'astro:content';

const auditioningNow = await getAuditioningNow();
const { data: extras } = (await getEntry('extras', 'extras'))!;
const { adultOptp, juniorOptp } = extras;
const contact = await getVenueContact();

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Auditions', url: '/auditions' },
]);
---

<DefaultLayout title="Auditions" description="Audition dates, requirements, and sign-up info for OPTP productions.">
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto max-w-(--container-narrow) px-4 py-16 text-center">
    <SectionHeading eyebrow="Get Involved" title="Auditions" align="center" />
  </div>

  <div class="mx-auto grid max-w-250 gap-8 px-4 pb-20 md:grid-cols-2">
    <DivisionAuditionPanel
      eyebrow="Adult OPTP"
      heading="Adult OPTP"
      description={adultOptp.description}
      auditionWindow={adultOptp.auditionWindow}
      contactEmail={adultOptp.contactEmail}
    />
    <DivisionAuditionPanel
      eyebrow="Junior OPTP"
      heading={juniorOptp.ageRange}
      description={juniorOptp.description}
      auditionWindow={juniorOptp.auditionWindow}
      performanceWindow={juniorOptp.performanceWindow}
      contactEmail={juniorOptp.contactEmail}
    />
  </div>

  {auditioningNow.length > 0 && (
    <div class="mx-auto max-w-250 px-4 pb-20">
      <SectionHeading eyebrow="Right Now" title="Auditioning Now" />
      <div class="mt-8 grid gap-8 md:grid-cols-2">
        {auditioningNow.map((listing) => (
          <AuditionNotice
            title={listing.title}
            href={listing.href}
            auditions={listing}
            fallbackContactEmail={contact.email}
          />
        ))}
      </div>
    </div>
  )}
</DefaultLayout>
