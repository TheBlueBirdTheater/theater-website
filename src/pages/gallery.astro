---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { Image } from 'astro:assets';
import { buildBreadcrumbSchema } from '@utils/schema';
import { getCollection } from 'astro:content';

const photos = await getCollection('gallery');

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Gallery', url: '/gallery' },
]);
---

<DefaultLayout title="Gallery" description="Production photos from shows at the Blue Bird Theatre.">
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto max-w-(--container-max) px-4 py-16">
    <SectionHeading title="Gallery" />
    {photos.length > 0 ? (
      <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        {photos.map((photo) => (
          <Image
            src={photo.data.photo}
            alt={photo.data.alt}
            format="webp"
            class="border-line rounded-lg aspect-square w-full border object-cover"
            loading="lazy"
          />
        ))}
      </div>
    ) : (
      <p class="font-body text-base-content/60 mt-8">Production photos coming soon.</p>
    )}
  </div>
</DefaultLayout>
