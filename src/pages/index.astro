---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
import Badge from '@components/Badge.astro';
import Button from '@components/Button.astro';
import InfoRow from '@components/InfoRow.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { buildPerformingGroupSchema, buildTheaterVenueSchema, buildEventSchema, OPTP_NAME, THEATRE_NAME } from '@utils/schema';
import { getCurrentShow } from '@utils/shows';
import { formatDateRange } from '@utils/dates';
import { getVenueContact } from '@data/venue';
import { getEntry } from 'astro:content';

const currentShow = await getCurrentShow();
const firstRunDate = currentShow?.data.runDates[0];

const { data: history } = (await getEntry('history', 'history'))!;
const contact = await getVenueContact();

const theaterSchema = buildTheaterVenueSchema({
  name: THEATRE_NAME,
  telephone: contact.phone,
  email: contact.email,
  address: contact.address,
});

const performingGroupSchema = buildPerformingGroupSchema({
  name: OPTP_NAME,
  sameAs: contact.socials.map((s) => s.url).filter((url) => url !== '#'),
  locationName: THEATRE_NAME,
});

const eventSchema = currentShow && firstRunDate
  ? buildEventSchema({
      name: currentShow.data.title,
      startDate: `${firstRunDate.date}T${firstRunDate.time}:00`,
      url: `/shows/${currentShow.id}`,
      venueName: currentShow.data.venue,
      venueAddress: contact.address,
      performerName: currentShow.data.performingGroup ?? OPTP_NAME,
      offerUrl: currentShow.data.ticketUrl,
      offerPrice: currentShow.data.ticketPrice,
      description: currentShow.data.synopsis,
    })
  : null;
---

<DefaultLayout
  title="Home"
  description="Blue Bird Theatre is a historic community theater in Orangeburg, SC, home to the Orangeburg Part-Time Players."
>
  <Schema schema={eventSchema ? [theaterSchema, performingGroupSchema, eventSchema] : [theaterSchema, performingGroupSchema]} />

  {currentShow && (
    <section class="mx-auto grid max-w-(--container-max) gap-14 px-4 py-14 md:grid-cols-[1.1fr_0.9fr] md:items-center md:py-16">
      <div>
        <Badge status={currentShow.data.status} />
        <h1 class="font-heading text-base-content mt-4 text-[2.75rem] leading-[1.08] font-semibold tracking-[-0.01em] sm:text-[4rem]">
          {currentShow.data.title}
        </h1>
        {currentShow.data.subtitle && (
          <p class="font-body text-base-content/60 mt-2 text-[1.1875rem] italic">{currentShow.data.subtitle}</p>
        )}
        <p class="font-body text-base-content mt-4 max-w-130">{currentShow.data.synopsis}</p>
        {firstRunDate && (
          <div class="mt-5 flex flex-wrap gap-5">
            <InfoRow label="Dates" value={formatDateRange(currentShow.data.runDates)} />
            <InfoRow label="Venue" value={currentShow.data.venue} />
          </div>
        )}
        <Button href={currentShow.data.ticketUrl} variant="primary" size="lg" class="mt-6">Get Tickets</Button>
      </div>
      <img
        src={currentShow.data.posterImage}
        alt={currentShow.data.posterAlt}
        class="border-line rounded-lg aspect-4/5 w-full max-w-sm justify-self-center border object-cover shadow-card"
      />
    </section>
  )}

  <section class="bg-primary">
    <div class="mx-auto max-w-(--container-narrow) px-4 py-18 text-center">
      <SectionHeading
        eyebrow="Since 1981"
        title="The largest community theater between Columbia and Charleston"
        align="center"
        onNavy
      />
      <p class="font-body text-light-blue-tint mx-auto mt-4 max-w-170 text-[1.1875rem]">{history.intro}</p>
      <Button href="/about" variant="inverse" class="mt-6">Read Our Story</Button>
    </div>
  </section>

  <NewsletterSignup />
</DefaultLayout>
