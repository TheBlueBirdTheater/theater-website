---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import { Image } from 'astro:assets';
import Badge from '@components/Badge.astro';
import Button from '@components/Button.astro';
import ShareButton from '@components/ShareButton.astro';
import InfoRow from '@components/InfoRow.astro';
import Divider from '@components/Divider.astro';
import VenueMap from '@components/VenueMap.astro';
import AddToCalendar from '@components/AddToCalendar.astro';
import KnowBeforeYouGo from '@components/KnowBeforeYouGo.astro';
import CountdownBanner from '@components/CountdownBanner.astro';
import { faShirt } from '@fortawesome/free-solid-svg-icons';
import { buildEventSchema, buildBreadcrumbSchema, OPTP_NAME } from '@utils/schema';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import { getVenueContact } from '@data/venue';
import { formatDate } from '@utils/dates';
import { getShowStatus } from '@utils/shows';
import { getNextShowing, type Showing } from '@utils/showings';
import { formatAccessibilitySummary } from '@utils/accessibility';

export async function getStaticPaths() {
  const shows = await getCollection('shows');
  return shows.map((show) => ({
    params: { slug: show.id },
    props: { show },
  }));
}

interface Props {
  show: CollectionEntry<'shows'>;
}

const { show } = Astro.props as Props;
const { data } = show;

const contact = await getVenueContact();
const performingGroup = data.performingGroup ?? OPTP_NAME;

const venueAddress = `${data.venue}, ${contact.address.streetAddress}, ${contact.address.addressLocality}, ${contact.address.addressRegion} ${contact.address.postalCode}`;

const showings: Showing[] = data.runDates.map((rd) => ({
  date: rd.date,
  time: rd.time,
  label: rd.label,
  accessibilityTag: rd.accessibilityTag,
}));
const { next: nextShowing, isPast: allShowingsPast } = getNextShowing(showings);

const parkingFaq = await getEntry('faqs', 'venue-parking');
const locationFaq = await getEntry('faqs', 'venue-location');

const eventSchemas = data.runDates.map((rd) =>
  buildEventSchema({
    name: data.title,
    // TODO: normalize to full ISO with real timezone once real run-date times are known
    startDate: `${rd.date}T${rd.time}:00`,
    url: `/shows/${show.id}`,
    venueName: data.venue,
    venueAddress: contact.address,
    performerName: performingGroup,
    offerUrl: data.ticketUrl,
    offerPrice: data.ticketPrice,
    description: data.synopsis,
    imageUrl: data.posterImage?.src,
  })
);

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Shows', url: '/shows' },
  { name: data.title, url: `/shows/${show.id}` },
]);
---

<DefaultLayout
  title={data.title}
  description={data.synopsis}
  image={data.posterImage?.src}
  imageAlt={data.posterAlt}
>
  <Schema schema={eventSchemas} />
  <Schema schema={breadcrumbSchema} />

  <CountdownBanner next={nextShowing} isPast={allShowingsPast} />

  <div class="mx-auto grid max-w-(--container-max) gap-14 px-4 py-14 md:grid-cols-[0.85fr_1.15fr]">
    {data.posterImage ? (
      <Image
        src={data.posterImage}
        alt={data.posterAlt}
        format="webp"
        class="border-line rounded-lg aspect-4/5 w-full border object-cover shadow-card"
      />
    ) : (
      <div class="border-line rounded-lg bg-base-200 text-base-content/70 font-body flex aspect-4/5 w-full items-center justify-center border text-sm">
        Poster coming soon
      </div>
    )}
    <div>
      <Badge status={getShowStatus(show)} />
      <h1 class="font-heading text-base-content mt-4 text-display leading-[1.08] font-semibold tracking-[-0.01em]">
        {data.title}
      </h1>
      {data.subtitle && <p class="font-body text-base-content/70 mt-2 text-lead italic">{data.subtitle}</p>}
      <p class="font-body text-base-content mt-4">{data.synopsis}</p>

      <div class="mt-7 grid gap-4.5 sm:grid-cols-2">
        <InfoRow
          label="Dates"
          value={data.runDates.length === 0
            ? 'TBA'
            : data.runDates
                .map((rd) => {
                  const dateLabel = rd.label ? `${rd.label}: ${formatDate(rd.date)}` : formatDate(rd.date);
                  return rd.accessibilityTag ? `${dateLabel} (${rd.accessibilityTag})` : dateLabel;
                })
                .join(' · ')}
        />
        <InfoRow label="Venue" value={data.venue} />
        <InfoRow label="Presented By" value={performingGroup} />
        {data.dressCode && <InfoRow label="Dress Code" value={data.dressCode} iconDef={faShirt} />}
      </div>

      <div class="mt-7">
        <VenueMap address={venueAddress} lat={contact.mapLat} lng={contact.mapLng} />
      </div>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <Button href={data.ticketUrl} variant="primary" size="lg">Get Tickets</Button>
        <AddToCalendar
          title={data.title}
          address={venueAddress}
          showings={showings}
          ticketUrl={data.ticketUrl}
          description={data.synopsis}
        />
        <ShareButton title={data.title} size="lg" />
      </div>

      <div class="mt-7">
        <KnowBeforeYouGo
          doorsOpenMinutesBefore={data.doorsOpenMinutesBefore}
          runTime={data.runTime}
          parkingAnswer={parkingFaq?.data.answer}
          locationAnswer={locationFaq?.data.answer}
          accessibilityNote={formatAccessibilitySummary(data.accessibility)}
          concessionsNote={data.concessionsNote}
          dressCode={data.dressCode}
        />
      </div>

      <div class="mt-10">
        <Divider />
      </div>

      <div class="mt-8 grid gap-8 sm:grid-cols-2">
        {data.cast && data.cast.length > 0 && (
          <div>
            <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">Cast</p>
            <p class="font-body text-base-content mt-2 leading-[1.9]">
              {data.cast.map((member, i) => (
                <>
                  {member}
                  {i < data.cast!.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        )}

        {data.crew && data.crew.length > 0 && (
          <div>
            <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">Crew</p>
            <p class="font-body text-base-content mt-2 leading-[1.9]">
              {data.crew.map((member, i) => (
                <>
                  {member}
                  {i < data.crew!.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</DefaultLayout>
