---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import { buildEventSchema, buildBreadcrumbSchema } from '@utils/schema';
import { shows, type Show } from '@data/season';

export function getStaticPaths() {
  return shows.map((show) => ({
    params: { slug: show.slug },
    props: { show },
  }));
}

interface Props {
  show: Show;
}

const { show } = Astro.props as Props;

const eventSchemas = show.runDates.map((rd) =>
  buildEventSchema({
    name: show.title,
    // TODO: normalize to full ISO with real timezone once real run-date times are known
    startDate: `${rd.date}T${rd.time}:00`,
    url: `/shows/${show.slug}`,
    venueName: show.venue,
    offerUrl: show.ticketUrl,
    description: show.synopsis,
    imageUrl: show.posterImage,
  })
);

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Shows', url: '/shows' },
  { name: show.title, url: `/shows/${show.slug}` },
]);
---

<DefaultLayout title={show.title} description={show.synopsis} image={show.posterImage} imageAlt={show.posterAlt}>
  <Schema schema={eventSchemas} />
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto grid max-w-5xl gap-8 px-4 py-16 md:grid-cols-[2fr_3fr]">
    <img
      src={show.posterImage}
      alt={show.posterAlt}
      class="rounded-box aspect-2/3 w-full object-cover shadow-lg"
    />
    <div>
      <h1 class="font-heading text-3xl font-bold">{show.title}</h1>
      {show.subtitle && <p class="mt-1 text-lg opacity-70">{show.subtitle}</p>}
      <p class="mt-4">{show.synopsis}</p>

      <h2 class="font-heading mt-8 text-xl font-semibold">Performance Dates</h2>
      <ul class="mt-2 space-y-1">
        {show.runDates.map((rd) => (
          <li>{rd.date} {rd.time}{rd.label && ` — ${rd.label}`}</li>
        ))}
      </ul>
      <p class="mt-2 text-sm opacity-70">{show.venue}</p>

      {show.cast && show.cast.length > 0 && (
        <>
          <h2 class="font-heading mt-8 text-xl font-semibold">Cast</h2>
          <ul class="mt-2 space-y-1">
            {show.cast.map((member) => <li>{member}</li>)}
          </ul>
        </>
      )}

      {show.crew && show.crew.length > 0 && (
        <>
          <h2 class="font-heading mt-8 text-xl font-semibold">Crew</h2>
          <ul class="mt-2 space-y-1">
            {show.crew.map((member) => <li>{member}</li>)}
          </ul>
        </>
      )}

      <a href={show.ticketUrl} class="btn btn-primary mt-8">Get Tickets</a>
    </div>
  </div>
</DefaultLayout>
