---
import DefaultLayout from '@layouts/DefaultLayout.astro';
import Schema from '@components/Schema.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Button from '@components/Button.astro';
import { buildBreadcrumbSchema } from '@utils/schema';
import { getCollection, getEntry } from 'astro:content';

const valueProps = await getCollection('valueProps');
const { data: donate } = (await getEntry('donate', 'donate'))!;
const { givingLevels, sponsorshipTiers, donationPlatformUrl } = donate;

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Support Us', url: '/donate' },
]);
---

<DefaultLayout title="Support Us" description="Support the Blue Bird Theatre by donating to the Orangeburg Part-Time Players, the nonprofit that operates it.">
  <Schema schema={breadcrumbSchema} />

  <div class="mx-auto max-w-(--container-narrow) px-4 py-16 text-center">
    <SectionHeading eyebrow="Support Us" title="Keep the curtain up at the Blue Bird" align="center" />
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {valueProps.map((vp) => (
        <div>
          <h3 class="font-heading text-base-content font-semibold">{vp.data.title}</h3>
          <p class="font-body text-base-content/70 mt-1">{vp.data.description}</p>
        </div>
      ))}
    </div>
    <!-- TODO: donationPlatformUrl points to a third-party giving platform once one is chosen -->
    <Button href={donationPlatformUrl} variant="primary" size="lg" class="mt-8">Give Now</Button>
  </div>

  <div class="mx-auto max-w-250 px-4 pb-14">
    <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">Giving Levels</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {givingLevels.map((level, i) => {
        const isPatron = i === givingLevels.length - 1 && givingLevels.length > 1;
        return (
          <div
            class:list={[
              'rounded-lg p-7',
              isPatron
                ? 'bg-primary text-primary-content'
                : 'border-line bg-base-100 border shadow-card',
            ]}
          >
            <h3 class="font-heading font-semibold">{level.name}</h3>
            <p class:list={['font-heading mt-1 text-stat font-semibold', isPatron ? 'text-secondary-accessible' : 'text-primary']}>
              {level.amount}
            </p>
            <ul
              class:list={[
                'font-body mt-3 space-y-1 text-sm',
                isPatron ? 'text-light-blue-tint' : 'text-base-content/70',
              ]}
            >
              {level.perks.map((perk) => <li>{perk}</li>)}
            </ul>
          </div>
        );
      })}
    </div>
  </div>

  <section class="bg-base-200">
    <div class="mx-auto max-w-250 px-4 py-14">
      <p class="font-body text-primary text-eyebrow font-semibold tracking-[0.09em] uppercase">
        Business Sponsorship
      </p>
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        {sponsorshipTiers.map((tier) => (
          <div class="border-line rounded-lg border bg-base-100 p-6.5">
            <h3 class="font-heading text-base-content font-semibold">{tier.name}</h3>
            <p class="font-body text-primary mt-1 text-sm">{tier.amount}</p>
            <ul class="font-body text-base-content/70 mt-3 space-y-1">
              {tier.benefits.map((benefit) => <li>{benefit}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>
